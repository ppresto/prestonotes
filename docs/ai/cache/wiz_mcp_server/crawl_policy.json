{
  "version": "1.0",
  "default_target_depth": 5,
  "max_allowed_depth": 9,
  "depth_strategy": "iterative_deepening",
  "stop_conditions": {
    "max_waves_without_new_links": 2,
    "max_total_calls_per_refresh_run": 120
  },
  "rate_limit_guardrails": {
    "base_delay_seconds": 8,
    "recovery_delay_seconds": 6,
    "backoff_multiplier_on_throttle": 1.5,
    "max_delay_seconds": 60
  },
  "notes": [
    "Use depth 5 for normal refresh runs to balance coverage and throttling risk.",
    "Use depth 9 only for periodic audit sweeps or when major docs restructuring is suspected."
  ]
}
