{
	"mcpServers": {
		"prestonotes": {
			"type": "stdio",
			"command": "uv",
			"args": ["run", "python", "-m", "prestonotes_mcp"],
			"cwd": "${workspaceFolder}",
			"env": {
				"PRESTONOTES_REPO_ROOT": "${workspaceFolder}"
			},
			"envFile": "${workspaceFolder}/.cursor/mcp.env"
		},
		"wiz-local": {
			"type": "stdio",
			"timeout": 60,
			"command": "${workspaceFolder}/wiz-mcp/run-wiz-mcp-for-cursor.sh",
			"args": [],
			"envFile": "${workspaceFolder}/.cursor/mcp.env"
		},
		"wiz-remote": {
			"timeout": 60,
			"url": "https://mcp.demo.wiz.io"
		}
	}
}
