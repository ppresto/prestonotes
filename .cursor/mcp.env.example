# Copy to `.cursor/mcp.env` (gitignored) and replace placeholders.
# Cursor loads this file for the `prestonotes` MCP server — see README Quick setup.
# Docs: https://cursor.com/docs/mcp

GDRIVE_BASE_PATH=/path/to/Google Drive/My Drive/MyNotes
# Optional: Granola local cache if not at default ~/Library/Application Support/Granola/cache-v*.json
# GRANOLA_CACHE_PATH=/path/to/cache-v5.json
MYNOTES_ROOT_FOLDER_ID=your-drive-folder-id
GCLOUD_ACCOUNT=you@example.com
GCLOUD_AUTH_LOGIN_COMMAND=gcloud auth login --account=you@example.com --enable-gdrive-access --force
# After copying to mcp.env, print this line in a terminal without opening the file: ./setEnv.sh --print-gdrive-auth

# GOOGLE_API_KEY=...   # Gemini / embeddings for wiz_knowledge_search (Stage 4)
# PRESTONOTES_GEMINI_EMBEDDING_MODEL=text-embedding-004

# Optional: wiz-local MCP (see repo root wiz-mcp/README.md). Same file is fine — do not commit secrets.
# WIZ_CLIENT_ID=...
# WIZ_CLIENT_SECRET=...
# WIZ_ENV=app
