# Copy to `.cursor/mcp.env` (gitignored) and replace placeholders.
# Cursor loads this file for the `prestonotes` MCP server — see README Quick setup.
# Docs: https://cursor.com/docs/mcp

GDRIVE_BASE_PATH=/path/to/Google Drive/My Drive/MyNotes
MYNOTES_ROOT_FOLDER_ID=your-drive-folder-id
GCLOUD_ACCOUNT=you@example.com
GCLOUD_AUTH_LOGIN_COMMAND=gcloud auth login --account=you@example.com --enable-gdrive-access --force
